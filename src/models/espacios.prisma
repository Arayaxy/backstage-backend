model Espacio {
  id_espacio        String @id @default(uuid(7)) @db.Uuid
  nombre_espacio    String
  ciudad            String
  direccion         String
  aforo             String
  nota              String
  telefono_contacto String
  nombre_contacto   String
  email_contacto    String
  salas             Sala[]

  @@map("espacios")
}
