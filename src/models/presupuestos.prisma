model Presupuesto {
  id_presupuesto       String  @id @default(uuid(7)) @db.Uuid
  estado_presupuesto   String
  total                Int
  fecha                String
  nota_ubicacion       String
  precio_ubicacion     Int
  nota_catering        String
  precio_catering      Int
  nota_audiovisuales   String
  precio_audiovisuales Int
  nota_otros           String
  precio_otros         Int
  catering             Boolean @default(false)
  audiovisuales        Boolean @default(false)
  otros                Boolean @default(false)
  observaciones        String
  eventoId             String  @db.Uuid
  evento               Evento  @relation(fields: [eventoId], references: [id_evento])

  @@map("presupuestos")
}
