model Evento {
  id_evento        String          @id @default(uuid(7)) @db.Uuid
  nombre_evento    String
  ciudad           String
  lugar_confirmado String
  fecha_inicio     String
  fecha_fin        String
  numero_personas  Int
  tipo_evento      String
  nota             String
  clienteId        String          @db.Uuid
  cliente          Cliente         @relation(fields: [clienteId], references: [id_cliente])
  estadoId         String          @db.Uuid
  estado           Estado          @relation(fields: [estadoId], references: [id_estado])
  salaId           String?         @db.Uuid
  sala             Sala?           @relation(fields: [salaId], references: [id_sala])
  presupuestos     Presupuesto[]
  eventos_ponente  Eventos_ponente[]

  @@map("eventos")
}
